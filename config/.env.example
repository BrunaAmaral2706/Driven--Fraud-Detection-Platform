# Driven Fraud Detection Platform — Environment Configuration
# Copy to backend/.env:  cp config/.env.example backend/.env

# Application
APP_NAME=Driven Fraud Detection Platform
APP_VERSION=1.0.0
DEBUG=true

# Database
# Development (SQLite — zero-config)
DATABASE_URL=sqlite:///./fraud.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driven_fraud

# CORS (JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ML Pipeline (optional)
# ML_MODEL_PATH=ml-pipeline/models/fraud_scorer.pkl
# ML_INFERENCE_ENABLED=false

# AI Reports (optional — future LLM integration)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your-key-here
